{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Aspex",
  "logo": {
    "light": "/logo/logo.svg",
    "dark": "/logo/logo.svg"
  },
  "favicon": "/logo/logo.svg",
  "colors": {
    "primary": "#7c5cfc",
    "light": "#a78bfa",
    "dark": "#5b44c3",
